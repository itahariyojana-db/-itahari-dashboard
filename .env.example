# HTTP Basic Auth credentials.
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# Set these same variables in Vercel: Project → Settings → Environment Variables

BASIC_AUTH_USER=your-username-here
BASIC_AUTH_PASSWORD=your-strong-password-here

# HMAC-SHA256 session signing key — minimum 32 random characters
# Generate: openssl rand -base64 32
SESSION_SECRET=your-random-secret-here
